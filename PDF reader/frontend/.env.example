# Required when the UI is on a different origin than the API (e.g. UI :5174, API :6000).
VITE_API_BASE_URL=http://117.254.196.100:6000

# If you use Nginx (or similar) so the browser only talks to one host and /upload is proxied
# to the backend, remove VITE_API_BASE_URL and rebuild so the app uses relative /upload.
